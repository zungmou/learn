---
layout: none
permalink: /api/latest.json
---
{
  "show_excerpts": {{ site.show_excerpts | jsonify }},
  "moments": [
    {% assign moments = site.posts | sort: 'date' | reverse %}
    {% for item in moments limit:20 %}
      {
        "date": "{{ item.date | date: '%b %d, %y' }}",
        "url": "{{ item.url | relative_url }}",
        "content": {{ item.content | jsonify }},
        "id": {{ item.url | jsonify }}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ],
  "posts": [
    {% assign posts = site.posts | sort: 'date' | reverse %}
    {% for item in posts limit:20 %}
      {
        "date": "{{ item.date | date: '%b %d, %y' }}",
        "title": {{ item.title | jsonify }},
        "category": {{ item.category | jsonify }},
        "category_display": {{ site.category_names[item.category] | default: item.category | jsonify }},
        "url": "{{ item.url | relative_url }}",
        "excerpt": {{ item.excerpt | jsonify }},
        "id": {{ item.url | jsonify }}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
